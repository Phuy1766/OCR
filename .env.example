# ==========================================================================
# Hệ thống quản lý công văn — Local development environment variables
# Copy this file to `.env` and adjust values. Never commit `.env`.
# ==========================================================================

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=congvan
POSTGRES_USER=congvan
POSTGRES_PASSWORD=congvan_dev_password_change_me

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- RabbitMQ ----
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=congvan
RABBITMQ_PASSWORD=congvan_dev_password_change_me
RABBITMQ_VHOST=/

# ---- MinIO ----
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=congvan_admin
MINIO_ROOT_PASSWORD=congvan_dev_password_change_me
MINIO_BUCKET_DOCUMENTS=congvan-documents
MINIO_BUCKET_SIGNED=congvan-signed

# ---- Backend (Spring Boot) ----
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
JWT_PRIVATE_KEY_PATH=/app/certs/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/app/certs/jwt-public.pem
JWT_ACCESS_TOKEN_TTL_MINUTES=30
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ---- Frontend (Next.js) ----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_NAME="Hệ thống quản lý công văn"

# ---- OCR service (FastAPI) ----
OCR_SERVICE_PORT=5000
OCR_INTERNAL_API_KEY=change_me_internal_shared_secret
OCR_PADDLE_LANG=vi

# ---- App defaults ----
APP_TIMEZONE=Asia/Ho_Chi_Minh
APP_LOCALE=vi_VN
